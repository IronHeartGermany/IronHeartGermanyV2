{%- comment -%}
  FAQ Question-Fragmente (schema.org/Question)
  Iron Heart Germany — GEO/SEO Optimierung

  Wird aus section-accordions.liquid heraus gerendert,
  sobald das Template `page.faq` ist (Seite: /pages/faqs).

  WICHTIG:
  Google verlangt exakt ein FAQPage pro URL. Da die FAQ-Seite
  mehrere section-accordions enthält (eine pro Kategorie),
  emittiert jede Section hier nur ihre Question-Objekte als JSON-
  Fragment. Das Bootstrap-Snippet `jsonld-faq-bootstrap` (eingebunden
  in theme.liquid) aggregiert alle Fragmente und schreibt ein
  einziges FAQPage-Script in den Head.

  Erwartet im Kontext: `section` (die aktuelle section-accordions).
{%- endcomment -%}

{%- assign faq_count = 0 -%}
{%- capture faq_items -%}
  {%- for block in section.blocks -%}
    {%- assign q_title = block.settings.title | strip -%}
    {%- assign q_answer = pages[block.settings.raw_content].content | default: block.settings.text -%}
    {%- assign q_answer_clean = q_answer | strip -%}

    {%- if q_title != blank and q_answer_clean != blank -%}
      {%- if faq_count > 0 -%},{%- endif -%}
      {
        "@type": "Question",
        "name": {{ q_title | strip_html | strip | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ q_answer_clean | json }}
        }
      }
      {%- assign faq_count = faq_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- if faq_count > 0 -%}
<script type="application/json" data-faq-questions data-faq-section="{{ section.id }}">
[{{ faq_items }}]
</script>
{%- endif -%}