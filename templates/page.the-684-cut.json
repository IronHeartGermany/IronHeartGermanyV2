    "section_accordions_BdTXWr": {
      "type": "section-accordions",
      "blocks": {
        "text_a9LF8h": {
          "type": "text",
          "settings": {
            "title": "What is the Iron Heart 684 cut?",
            "text": "<p>The 684 is a relaxed straight fit developed in collaboration between Iron Heart Japan and Iron Heart Germany.</p><p>It is based on the iconic 634 silhouette but offers more room through the thigh and a straight leg opening without taper. The 684 will become part of the international Iron Heart collection in future denim variations.</p>"
          }
        },
        "text_NXHHb4": {
          "type": "text",
          "settings": {
            "title": "What is exclusive about the IH-684S-16-GER?",
            "text": "<p>The IH-684S-16-GER is the very first release of the new 684 cut.</p><p>While the 684 fit will later be introduced internationally in other denim fabrics, this inaugural version — combining the 684 silhouette with the 16oz Japanese selvedge denim — is exclusive to Iron Heart Germany.</p><p>The 16oz fabric is also used for other Iron Heart garments, but this 684 configuration is exclusive to Iron Heart Germany.</p>"
          }
        },
        "text_XnDFa7": {
          "type": "text",
          "settings": {
            "title": "What makes the 16oz Japanese selvedge denim special?",
            "text": "<p>The 16oz selvedge denim used for the IH-684S-16-GER was woven in Kojima, Japan by Takata Orimono using ring-spun Pima cotton yarns.</p><p>It features:</p><ul><li>A textured, slightly irregular twill structure</li><li>Strong vertical “tate-ochi” fading potential</li><li>A balanced 16oz weight suitable for year-round wear</li><li>Classic indigo ageing with high contrast development</li></ul>"
          }
        },
        "text_9HNCN7": {
          "type": "text",
          "settings": {
            "title": "Where and when can I buy the IH-684S-16-GER?",
            "text": "<p>The first release will take place exclusively at the Iron Heart Germany store in Hamburg during a dedicated launch event in late March / early April.</p><p>Following the in-store release, remaining stock will become available via the official Iron Heart Germany webshop, serving customers across Europe and internationally.</p>"
          }
        },
        "text_N9DHGR": {
          "type": "text",
          "settings": {
            "title": "Is the IH-684S-16-GER a limited edition?",
            "text": "<p>The initial production run is limited.</p><p>However, the 684 cut itself is not a one-off model. It will be integrated into the broader Iron Heart range in future denim fabrics. The 16oz selvedge edition remains exclusive to Iron Heart Germany.</p>"
          }
        },
        "text_DnQTa3": {
          "type": "text",
          "settings": {
            "title": "Can I receive fitting advice or hemming at the Hamburg store?",
            "text": "<p>Yes. At the Iron Heart Germany store in Hamburg, our team provides personal fitting advice, measurement guidance and product consultation.</p><p>We also offer professional chain-stitch hemming using our Union Special 43200G machine from 1939.</p>"
          }
        }
      },
